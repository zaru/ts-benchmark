{
  "name": "nestjs-standalone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "predev": "tsc",
    "dev": "tsc -w --preserveWatchOutput & node --watch dist/node.js",
    "predev:fastify": "tsc",
    "dev:fastify": "tsc -w --preserveWatchOutput & node --watch dist/fastify.js",
    "start": "node dist/node.js",
    "start:fastify": "node dist/fastify.js"
  },
  "dependencies": {
    "@elysia-bench/payload": "workspace:*",
    "@elysia-bench/workload": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
