{
  "name": "elysia-bench",
  "version": "1.0.0",
  "private": true,
  "description": "ElysiaJS 単体 vs Next.js連携 のリクエストベンチマーク",
  "scripts": {
    "start:elysia": "pnpm --filter elysia-standalone start",
    "start:elysia:bun": "pnpm --filter elysia-standalone start:bun",
    "dev:elysia": "pnpm --filter elysia-standalone dev",
    "dev:elysia:bun": "pnpm --filter elysia-standalone dev:bun",
    "start:hono": "pnpm --filter hono-standalone start",
    "start:hono:bun": "pnpm --filter hono-standalone start:bun",
    "dev:hono": "pnpm --filter hono-standalone dev",
    "dev:hono:bun": "pnpm --filter hono-standalone dev:bun",
    "start:express": "pnpm --filter express-standalone start",
    "start:express:bun": "pnpm --filter express-standalone start:bun",
    "dev:express": "pnpm --filter express-standalone dev",
    "dev:express:bun": "pnpm --filter express-standalone dev:bun",
    "build:next": "pnpm --filter next-elysia build",
    "start:next": "pnpm --filter next-elysia start",
    "dev:next": "pnpm --filter next-elysia dev",
    "build:tanstack": "pnpm --filter tanstack-elysia build",
    "start:tanstack": "pnpm --filter tanstack-elysia start",
    "dev:tanstack": "pnpm --filter tanstack-elysia dev",
    "build:astro": "pnpm --filter astro-elysia build",
    "start:astro": "pnpm --filter astro-elysia start",
    "dev:astro": "pnpm --filter astro-elysia dev",
    "build:adonis": "pnpm --filter adonis-elysia build",
    "start:adonis": "pnpm --filter adonis-elysia start",
    "dev:adonis": "pnpm --filter adonis-elysia dev",
    "build:solid": "pnpm --filter solidstart-elysia build",
    "start:solid": "pnpm --filter solidstart-elysia start",
    "dev:solid": "pnpm --filter solidstart-elysia dev",
    "build:svelte": "pnpm --filter sveltekit-elysia build",
    "start:svelte": "pnpm --filter sveltekit-elysia start",
    "dev:svelte": "pnpm --filter sveltekit-elysia dev",
    "build:nuxt": "pnpm --filter nuxt-elysia build",
    "start:nuxt": "pnpm --filter nuxt-elysia start",
    "dev:nuxt": "pnpm --filter nuxt-elysia dev",
    "seed": "pnpm --filter @elysia-bench/workload seed",
    "bench": "bash bench/run.sh"
  },
  "packageManager": "pnpm@10.24.0"
}
